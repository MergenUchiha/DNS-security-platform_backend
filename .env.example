# Backend .env — скопируй в backend/.env и заполни

# Сервер
PORT=3000
NODE_ENV=development

# База данных (PostgreSQL)
DATABASE_URL="postgresql://postgres:Uchiha_11@localhost:5432/dns_lab-db?schema=public"

# DNS резолверы
# Если API запускается ЛОКАЛЬНО (npm run start:dev):
# DNS_LEGIT_HOST=localhost
# DNS_LEGIT_PORT=1053
# DNS_SPOOF_HOST=localhost
# DNS_SPOOF_PORT=2053

# Если API запускается в DOCKER (docker compose):
DNS_LEGIT_HOST=coredns_legit
DNS_LEGIT_PORT=53
DNS_SPOOF_HOST=coredns_spoof
DNS_SPOOF_PORT=53

# IP-адреса сайтов
LEGIT_IP=172.20.0.11
FAKE_IP=172.20.0.12
LEGIT_SITE_URL=http://localhost:8081
FAKE_SITE_URL=http://localhost:8082

# Дефолтная политика митигации
DEFAULT_POLICY_DOMAIN=bank.lab
DEFAULT_POLICY_ACTION=FORCE_SAFE_IP
