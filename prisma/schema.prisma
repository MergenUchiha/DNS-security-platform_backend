generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LabMode {
  SAFE
  ATTACK
  MITIGATED
}

enum EventType {
  SESSION_STARTED
  SESSION_ENDED

  DNS_QUERY
  DNS_RESPONSE

  MODE_CHANGED
  LAB_RESET

  MITIGATION_POLICY_UPSERTED
  MITIGATION_ENABLED
  MITIGATION_DISABLED

  SPOOF_DETECTED
  SPOOF_BLOCKED
  SAFE_RESOLUTION_FORCED

  ERROR
}

model LabSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  endedAt   DateTime?
  mode      LabMode  @default(SAFE)

  events   Event[]
  policies MitigationPolicy[]
  queries  DnsQuery[]
}

model Event {
  id        String    @id @default(cuid())
  ts        DateTime  @default(now())
  type      EventType
  severity  String    @default("INFO") // INFO/WARN/ALERT
  payload   Json?

  sessionId String
  session   LabSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, ts])
  @@index([type, ts])
}

model MitigationPolicy {
  id         String   @id @default(cuid())
  domain     String
  action     String   // BLOCK | FORCE_SAFE_IP
  allowedIps String[]

  sessionId String
  session   LabSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, domain])
}

model DnsQuery {
  id       String   @id @default(cuid())
  ts       DateTime @default(now())
  name     String
  qtype    String   // A/AAAA/CNAME
  resolver String   // LEGIT | SPOOF
  answer   String?
  ttl      Int?
  rttMs    Int?

  finalAnswer String?
  finalAction String? // PASS | BLOCK | FORCE_SAFE_IP

  sessionId String
  session   LabSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, ts])
}