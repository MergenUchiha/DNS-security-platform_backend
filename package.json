    "@nestjs/swagger": "7.4.2",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "dns2": "2.1.0",
    "dotenv": "16.4.5",
    "helmet": "7.1.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "@prisma/client": "5.7.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.3.2",
    "@nestjs/schematics": "10.1.2",
    "@nestjs/testing": "10.3.8",
